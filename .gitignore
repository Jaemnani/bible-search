# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# large data files
/datas/
/public/data/*.bin  # 만약 50MB가 넘으면 제외해야 할 수도 있음
!/public/data/*.json
!/public/data/*.bin
# 단락 사전생성 체크포인트 (런타임 산출물 — commit 제외)
/public/data/passage_progress.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
